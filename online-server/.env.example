PORT=4545
NODE_ENV=development

# ضع هنا رابط Supabase PostgreSQL بعد استبدال [YOUR-PASSWORD] بالباسورد الحقيقي
# مثال:
# CONTROL_DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
CONTROL_DATABASE_URL=PUT_YOUR_SUPABASE_DATABASE_URL_HERE

# مفتاح طويل عشوائي للتوكن
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET

# أول أدمن للنظام
SYSTEM_ADMIN_USERNAME=admin
SYSTEM_ADMIN_PASSWORD=change_me_please
